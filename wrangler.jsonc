{
  "main": "dist/_worker.js/index.js",
  "name": "probably-hallucinating",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "routes": [
    {
      "pattern": "probablyhallucinating.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  },
  "$schema": "node_modules/wrangler/config-schema.json"
}
