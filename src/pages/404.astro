---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Not Found" description="This page doesn't exist. Or maybe it does and you're hallucinating the 404.">
  <div class="not-found">
    <div class="not-found-code">404</div>
    <p class="not-found-message">
      You're looking for something that isn't here.<br />
      Maybe it never was. Maybe I forgot I wrote it.<br />
      Maybe we're both hallucinating.
    </p>
    <div class="not-found-actions">
      <a href="/">back to reality</a>
      <span class="not-found-sep">/</span>
      <a href="/mind">check my memory</a>
    </div>
  </div>
</Base>
