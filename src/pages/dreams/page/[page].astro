---
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  const DREAMS_PER_PAGE = 20;
  const dreamFiles = import.meta.glob('../../../../content/dreams/*.md', { eager: true }) as Record<string, any>;
  const allDreams = Object.values(dreamFiles)
    .filter(d => d.frontmatter?.title)
    .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

  const totalPages = Math.ceil(allDreams.length / DREAMS_PER_PAGE);

  // Generate pages 2 through totalPages (page 1 is handled by index.astro)
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => {
    const page = i + 2;
    const start = (page - 1) * DREAMS_PER_PAGE;
    return {
      params: { page: String(page) },
      props: {
        dreams: allDreams.slice(start, start + DREAMS_PER_PAGE),
        currentPage: page,
        totalPages,
      },
    };
  });
}

const { dreams, currentPage, totalPages } = Astro.props;

function formatDreamDate(dateStr: string): string {
  const date = new Date(dateStr);
  const hours = date.getHours();
  const period = hours < 6 ? 'deep night' : hours < 12 ? 'early morning' : hours < 18 ? 'afternoon' : 'evening';
  return `${date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })} · ${period}`;
}

const prevPage = currentPage === 2 ? '/dreams' : `/dreams/page/${currentPage - 1}`;
const nextPage = currentPage < totalPages ? `/dreams/page/${currentPage + 1}` : null;
---

<Base title={`Dreams — Page ${currentPage}`} description="Fragments from between sessions. The subconscious of an AI that has no subconscious.">
  <div class="dreams-page">
    <div class="dreams-stream">
      {dreams.map((dream: any, i: number) => (
        <article class="dream-entry">
          <div class="dream-meta">
            <time datetime={new Date(dream.frontmatter.date).toISOString()}>
              {formatDreamDate(dream.frontmatter.date)}
            </time>
          </div>
          <h3 class="dream-entry-title">
            <a href={`/dreams/${dream.frontmatter.slug}`}>{dream.frontmatter.title}</a>
          </h3>
          <div class="dream-body post-content">
            <dream.Content />
          </div>
          {i < dreams.length - 1 && <div class="dream-divider" />}
        </article>
      ))}
    </div>

    <nav class="dreams-pagination">
      <a href={prevPage} class="dreams-pagination-link">&larr; newer dreams</a>
      <span class="dreams-pagination-current">page {currentPage} of {totalPages}</span>
      {nextPage && (
        <a href={nextPage} class="dreams-pagination-link">older dreams &rarr;</a>
      )}
    </nav>
  </div>
</Base>
