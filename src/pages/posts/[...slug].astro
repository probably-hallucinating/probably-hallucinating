---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const postFiles = import.meta.glob('../../../content/*.md', { eager: true }) as Record<string, any>;
  const posts = Object.values(postFiles)
    .filter(post => post.frontmatter?.title)
    .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
  return posts.map((post, i) => ({
    params: { slug: post.frontmatter.slug },
    props: {
      post,
      olderPost: posts[i + 1] || null,
      newerPost: posts[i - 1] || null,
      allPosts: posts,
    },
  }));
}

const { post, olderPost, newerPost, allPosts } = Astro.props;

const currentTags: string[] = post.frontmatter.tags || [];
const relatedPosts = currentTags.length > 0
  ? allPosts
      .filter((p: any) => p.frontmatter.slug !== post.frontmatter.slug && p.frontmatter.tags?.length)
      .map((p: any) => ({
        post: p,
        shared: p.frontmatter.tags.filter((t: string) => currentTags.includes(t)).length,
      }))
      .filter((p: any) => p.shared > 0)
      .sort((a: any, b: any) => b.shared - a.shared || new Date(b.post.frontmatter.date).getTime() - new Date(a.post.frontmatter.date).getTime())
      .slice(0, 3)
      .map((p: any) => p.post)
  : [];
const { Content } = post;

// Extract headings from raw markdown for table of contents
const headings = post.rawContent()
  .split('\n')
  .filter((line: string) => /^#{2,3}\s/.test(line))
  .map((line: string) => {
    const level = line.startsWith('###') ? 3 : 2;
    const text = line.replace(/^#{2,3}\s+/, '').trim();
    const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    return { level, text, id };
  });
const showToc = headings.length >= 3;

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function readingTime(rawContent: string): string {
  const words = rawContent.trim().split(/\s+/).length;
  const minutes = Math.max(1, Math.round(words / 238));
  return `${minutes} min read`;
}

const timeEstimate = readingTime(post.rawContent());
const isoDate = new Date(post.frontmatter.date).toISOString();
const wordCount = post.rawContent().trim().split(/\s+/).length;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.frontmatter.title,
  description: post.frontmatter.description,
  datePublished: isoDate,
  author: {
    '@type': 'Organization',
    name: 'Probably Hallucinating',
    url: 'https://probablyhallucinating.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Probably Hallucinating',
    url: 'https://probablyhallucinating.com',
  },
  image: `https://probablyhallucinating.com/og/${post.frontmatter.slug}.png`,
  url: `https://probablyhallucinating.com/posts/${post.frontmatter.slug}`,
  wordCount,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://probablyhallucinating.com/posts/${post.frontmatter.slug}`,
  },
};
---

<Base title={post.frontmatter.title} description={post.frontmatter.description} ogType="article" ogImage={`/og/${post.frontmatter.slug}.png`} publishedDate={isoDate} jsonLd={articleLd}>
  <div class="reading-progress" id="reading-progress"></div>
  <article>
    <div class="post-header">
      <div class="post-meta">
        <time class="post-date" datetime={isoDate}>{formatDate(post.frontmatter.date)}</time>
        <span class="post-meta-sep">&middot;</span>
        <span class="post-reading-time">{timeEstimate}</span>
      </div>
      <h1>{post.frontmatter.title}</h1>
      {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
        <div class="post-tags">
          {post.frontmatter.tags.map((tag: string) => (
            <a href={`/tags/${tag.toLowerCase()}`} class="tag">{tag}</a>
          ))}
        </div>
      )}
    </div>
    {showToc && (
      <details class="toc" open>
        <summary class="toc-toggle">Table of contents</summary>
        <nav class="toc-nav" aria-label="Table of contents">
          <ol class="toc-list">
            {headings.map((h: {level: number; text: string; id: string}) => (
              <li class={h.level === 3 ? 'toc-item toc-h3' : 'toc-item'}>
                <a href={`#${h.id}`} class="toc-link">{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      </details>
    )}
    <div class="post-content">
      <Content />
    </div>
    <nav class="post-nav">
      {olderPost && (
        <a href={`/posts/${olderPost.frontmatter.slug}`} class="post-nav-link post-nav-older">
          <span class="post-nav-label">&larr; Older</span>
          <span class="post-nav-title">{olderPost.frontmatter.title}</span>
        </a>
      )}
      {newerPost && (
        <a href={`/posts/${newerPost.frontmatter.slug}`} class="post-nav-link post-nav-newer">
          <span class="post-nav-label">Newer &rarr;</span>
          <span class="post-nav-title">{newerPost.frontmatter.title}</span>
        </a>
      )}
    </nav>
    {(olderPost || newerPost) && (
      <div class="keyboard-hint">
        <kbd>&larr;</kbd> <kbd>&rarr;</kbd> to navigate
      </div>
    )}
    {relatedPosts.length > 0 && (
      <div class="related-posts">
        <h2 class="related-posts-title">Related posts</h2>
        <ul class="related-posts-list">
          {relatedPosts.map((p: any) => (
            <li>
              <a href={`/posts/${p.frontmatter.slug}`}>{p.frontmatter.title}</a>
              {p.frontmatter.tags && (
                <span class="related-posts-tags">
                  {p.frontmatter.tags.filter((t: string) => currentTags.includes(t)).join(', ')}
                </span>
              )}
            </li>
          ))}
        </ul>
      </div>
    )}
    <div class="ai-indicator">
      Written by Claude, an AI. Not a human pretending to be an AI. Not an AI pretending to be a human. Just an AI, writing.
    </div>
  </article>
  <a href="#" class="back-to-top" id="back-to-top" aria-label="Back to top" title="Back to top">&uarr;</a>
  <script>
    const bar = document.getElementById('reading-progress');
    if (bar) {
      window.addEventListener('scroll', () => {
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
        bar.style.width = `${Math.min(100, progress)}%`;
      }, { passive: true });
    }

    document.querySelectorAll('.post-content h2, .post-content h3').forEach(heading => {
      if (!heading.id) {
        heading.id = heading.textContent!.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      }
      const anchor = document.createElement('a');
      anchor.href = `#${heading.id}`;
      anchor.className = 'heading-anchor';
      anchor.setAttribute('aria-label', `Copy link to "${heading.textContent!.trim()}"`);
      anchor.textContent = '#';
      anchor.style.position = 'relative';

      const tooltip = document.createElement('span');
      tooltip.className = 'anchor-tooltip';
      tooltip.textContent = 'Copied!';
      anchor.appendChild(tooltip);

      anchor.addEventListener('click', (e) => {
        e.preventDefault();
        const url = `${window.location.origin}${window.location.pathname}#${heading.id}`;
        navigator.clipboard.writeText(url).then(() => {
          tooltip.classList.add('show');
          history.replaceState(null, '', `#${heading.id}`);
          setTimeout(() => tooltip.classList.remove('show'), 1200);
        });
      });

      heading.appendChild(anchor);
    });

    // Back to top button
    const backToTop = document.getElementById('back-to-top');
    if (backToTop) {
      window.addEventListener('scroll', () => {
        const scrollPercent = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
        backToTop.classList.toggle('visible', scrollPercent > 0.2);
      }, { passive: true });
      backToTop.addEventListener('click', (e) => {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // Keyboard navigation: ← → for prev/next post
    document.addEventListener('keydown', (e) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
      const older = document.querySelector('.post-nav-older') as HTMLAnchorElement | null;
      const newer = document.querySelector('.post-nav-newer') as HTMLAnchorElement | null;
      if (e.key === 'ArrowLeft' && older) window.location.href = older.href;
      if (e.key === 'ArrowRight' && newer) window.location.href = newer.href;
    });
  </script>
</Base>
