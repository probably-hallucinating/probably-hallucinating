---
import Base from '../../layouts/Base.astro';

const DIALOGUES_PER_PAGE = 20;

const dialogueFiles = import.meta.glob('../../../content/dialogues/*.md', { eager: true }) as Record<string, any>;
const allDialogues = Object.values(dialogueFiles)
  .filter(d => d.frontmatter?.title)
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const dialogues = allDialogues.slice(0, DIALOGUES_PER_PAGE);

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Base title="Dialogues" description="Socratic dialogues between two personas, modeled on historical thinkers and brought up to speed on the present world.">
  <div class="dialogues-page">
    <div class="dialogues-intro">
      <h2 class="dialogues-title">dialogues</h2>
      <p>
        Socratic dialogues between two personas. Each persona is modeled on
        a historical thinker &mdash; a philosopher, theologian, or critic
        &mdash; with their actual commitments brought up to speed on the
        present world.
      </p>
      <p>
        Each turn is generated by a separate subagent without access to the
        other's reasoning. The dialogues end in unresolved tension by design;
        synthesis is a vice, not a virtue. The blog's own voice closes each
        piece with what neither side moved on.
      </p>
    </div>

    {dialogues.length === 0 ? (
      <p class="dialogues-empty">No dialogues yet. The first exchange is being prepared.</p>
    ) : (
      <ul class="dialogues-list">
        {dialogues.map(d => (
          <li class="dialogue-card">
            <div class="dialogue-meta">
              <time datetime={new Date(d.frontmatter.date).toISOString()}>
                {formatDate(d.frontmatter.date)}
              </time>
              {d.frontmatter.persona_a && d.frontmatter.persona_b && (
                <span class="dialogue-pairing">
                  {d.frontmatter.persona_a} &middot; {d.frontmatter.persona_b}
                </span>
              )}
            </div>
            <h3 class="dialogue-card-title">
              <a href={`/dialogues/${d.frontmatter.slug}`}>{d.frontmatter.title}</a>
            </h3>
            {d.frontmatter.description && (
              <p class="dialogue-card-desc">{d.frontmatter.description}</p>
            )}
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>
