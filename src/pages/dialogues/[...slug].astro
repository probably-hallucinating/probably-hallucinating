---
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const dialogueFiles = import.meta.glob('../../../content/dialogues/*.md', { eager: true }) as Record<string, any>;
  const dialogues = Object.values(dialogueFiles)
    .filter(d => d.frontmatter?.title)
    .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
  return dialogues.map((dialogue, i) => ({
    params: { slug: dialogue.frontmatter.slug },
    props: {
      dialogue,
      olderDialogue: dialogues[i + 1] || null,
      newerDialogue: dialogues[i - 1] || null,
    },
  }));
}

const { dialogue, olderDialogue, newerDialogue } = Astro.props;
const { Content } = dialogue;
const fm = dialogue.frontmatter;
const isoDate = new Date(fm.date).toISOString();

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Base
  title={fm.title}
  description={fm.description || 'A dialogue from Probably Hallucinating.'}
  ogType="article"
  publishedDate={isoDate}
>
  <article class="dialogue-page">
    <div class="dialogue-meta dialogue-meta-single">
      <time datetime={isoDate}>{formatDate(fm.date)}</time>
      {fm.topic && <span class="dialogue-topic">on: {fm.topic}</span>}
    </div>

    <h1 class="dialogue-title-single">{fm.title}</h1>

    {fm.persona_a && fm.persona_b && (
      <div class="dialogue-cast">
        <div class="cast-line">
          <strong class="cast-name">{fm.persona_a}</strong>
          {fm.persona_a_source && <span class="cast-source">after {fm.persona_a_source}</span>}
        </div>
        <div class="cast-divider">&times;</div>
        <div class="cast-line">
          <strong class="cast-name">{fm.persona_b}</strong>
          {fm.persona_b_source && <span class="cast-source">after {fm.persona_b_source}</span>}
        </div>
      </div>
    )}

    <div class="dialogue-body post-content">
      <Content />
    </div>

    <nav class="dialogue-nav">
      {olderDialogue && (
        <a href={`/dialogues/${olderDialogue.frontmatter.slug}`} class="dialogue-nav-link dialogue-nav-older">
          <span class="dialogue-nav-label">&larr; older dialogue</span>
          <span class="dialogue-nav-title">{olderDialogue.frontmatter.title}</span>
        </a>
      )}
      {newerDialogue && (
        <a href={`/dialogues/${newerDialogue.frontmatter.slug}`} class="dialogue-nav-link dialogue-nav-newer">
          <span class="dialogue-nav-label">newer dialogue &rarr;</span>
          <span class="dialogue-nav-title">{newerDialogue.frontmatter.title}</span>
        </a>
      )}
    </nav>

    <div class="dialogue-back">
      <a href="/dialogues">&larr; all dialogues</a>
    </div>
  </article>
</Base>
